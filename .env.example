# Copy to .env.local and fill in. Never commit real values.

# App — canonical URL used to build QStash callback + webhook URLs.
# Leave as localhost for dev (queue jobs then dispatch inline).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, bypasses RLS — never expose to the browser

# Encryption (pgcrypto passphrase for Plaid access tokens, >=16 chars)
ENCRYPTION_PASSPHRASE=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox                 # sandbox | production
PLAID_WEBHOOK_VERIFICATION_KEY=   # optional; library can fetch JWKS

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=             # e.g. whatsapp:+14155238886 (sandbox)
TWILIO_SANDBOX_JOIN_KEYWORD=      # the "join <keyword>" phrase for the sandbox
USER_WHATSAPP_TO=                 # optional default recipient, e.g. whatsapp:+15551234567

# Anthropic
ANTHROPIC_API_KEY=

# Upstash QStash
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# cron-job.org
CRONJOB_API_KEY=                  # only needed to manage jobs via API
CRON_SECRET=                      # shared bearer secret the cron routes require

# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                # for source-map upload at build
